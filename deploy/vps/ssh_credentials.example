# Copy this file to ssh_credentials.env (same folder), then update values.
VPS_HOST=178.104.135.205
VPS_PORT=22
VPS_USER=root
VPS_PASSWORD=your_vps_password_here

# Required for true 1-click mode (no host-key prompt).
VPS_HOSTKEY=ssh-ed25519 255 SHA256:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Browser launch target after startup
VPS_APP_SCHEME=http
VPS_APP_PORT=8000
VPS_APP_PATH=/

# Remote repo directory on VPS
VPS_REPO_DIR=~/notary_v2
