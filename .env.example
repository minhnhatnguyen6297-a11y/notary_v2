# Cấu hình API cho chức năng trích xuất dữ liệu tự động từ hình ảnh (OCR)
OPENAI_API_KEY=your_openai_api_key_here
OCR_MODEL=gpt-4o-mini

# Text-only LLM fallback for local OCR
OCR_TEXT_LLM_MODEL=gpt-4o-mini

# Celery queue (local)
CELERY_BROKER_URL=sqlalchemy+sqlite:///./ocr_jobs.db
CELERY_RESULT_BACKEND=db+sqlite:///./ocr_jobs.db

# Local OCR (optional)
LOCAL_OCR_YOLO_WEIGHTS=weights/cccd_yolo.pt
LOCAL_OCR_YOLO_CONF=0.25
LOCAL_OCR_DISABLE_TORCH=0
