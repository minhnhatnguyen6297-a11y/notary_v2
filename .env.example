# OCR cloud API
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=
# Qwen / DashScope OCR
QWEN_API_KEY=
# Model options for OCR AI route: qwen-vl-ocr-2025-11-20
OCR_MODEL=qwen-vl-ocr-2025-11-20
OCR_AI_CONCURRENCY=6
QWEN_OCR_BASE_URL=https://dashscope-intl.aliyuncs.com
QWEN_OCR_MIN_PIXELS=3072
QWEN_OCR_MAX_PIXELS=8388608
QWEN_OCR_ENABLE_ROTATE=0

# Text-only LLM fallback for local OCR
OCR_TEXT_LLM_MODEL=gpt-4o-mini

# Celery queue (local SQLite broker/backend)
CELERY_BROKER_URL=sqlalchemy+sqlite:///./ocr_jobs.db
CELERY_RESULT_BACKEND=db+sqlite:///./ocr_jobs.db

# Local OCR tuning
LOCAL_OCR_SMART_CROP_MIN_CONF=0.22
LOCAL_OCR_DET_MAX_SIDE_LEN=3000
LOCAL_OCR_VIETOCR_MODEL=vgg_transformer
LOCAL_OCR_VIETOCR_BATCH_SIZE=24
LOCAL_OCR_TORCH_THREADS=2
LOCAL_OCR_DENOISE=1
LOCAL_OCR_TIMING_LOG=1
LOCAL_OCR_TIMING_SLOW_MS=1500
LOCAL_OCR_DEBUG_LOG=1
LOCAL_OCR_DEBUG_MAX_BOX_LOG=8
LOCAL_OCR_REC_PAD_RATIO=0.10
LOCAL_OCR_REC_MIN_HEIGHT=48
LOCAL_OCR_REC_MAX_SCALE=3.0
LOCAL_OCR_TRIAGE_V2=1
LOCAL_OCR_TRIAGE_PROXY_MAX_SIDE=720
LOCAL_OCR_TRIAGE_MRZ_MIN_SCORE=0.20

# Logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
