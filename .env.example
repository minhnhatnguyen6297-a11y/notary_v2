# OCR cloud API
OPENAI_API_KEY=your_openai_api_key_here
OCR_MODEL=gpt-4o-mini

# Text-only LLM fallback for local OCR
OCR_TEXT_LLM_MODEL=gpt-4o-mini

# Celery queue (local SQLite broker/backend)
CELERY_BROKER_URL=sqlalchemy+sqlite:///./ocr_jobs.db
CELERY_RESULT_BACKEND=db+sqlite:///./ocr_jobs.db

# Optional Local OCR custom recognition model
LOCAL_OCR_REC_MODEL_PATH=
LOCAL_OCR_REC_KEYS_PATH=

# Local OCR tuning
LOCAL_OCR_SMART_CROP_MIN_CONF=0.22
LOCAL_OCR_MAX_SIDE_LEN=1536
LOCAL_OCR_TIMING_LOG=1
LOCAL_OCR_TIMING_SLOW_MS=1500
LOCAL_OCR_TRIAGE_V2=1
LOCAL_OCR_TRIAGE_FALLBACK_LEGACY=1
LOCAL_OCR_TRIAGE_PROXY_MAX_SIDE=720
LOCAL_OCR_TRIAGE_MRZ_MIN_SCORE=0.20

# Logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
